# Database Configuration
# Generate a secure connection string for your PostgreSQL database
DATABASE_URL="postgresql://user:password@localhost:5432/tfd"

# JWT Configuration
# IMPORTANT: Generate a secure random secret for production!
# Example: openssl rand -base64 32
JWT_SECRET="CHANGE_THIS_IN_PRODUCTION_min_32_chars_random_string"
JWT_EXPIRES_IN="8h"

# Server Configuration
PORT=3333

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"
